# XOceanus — Editor configuration
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# C++ source files — 4-space indent (matches existing codebase)
[*.{cpp,h,hpp,c}]
indent_style = space
indent_size = 4
max_line_length = 120

# Python tools — 4-space indent (PEP 8)
[*.py]
indent_style = space
indent_size = 4
max_line_length = 120

# CMake
[CMakeLists.txt]
indent_style = space
indent_size = 4

[*.cmake]
indent_style = space
indent_size = 4

# Swift (iOS/macOS companion app)
[*.swift]
indent_style = space
indent_size = 4

# JSON (presets, configs)
[*.{json,xometa}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Shell scripts
[*.sh]
indent_style = space
indent_size = 4
