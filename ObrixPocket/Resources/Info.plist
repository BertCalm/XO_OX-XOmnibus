<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>OBRIX Pocket</string>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>XO Reef Configuration</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>org.xo-ox.xoreef</string>
			</array>
		</dict>
	</array>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSAppleMusicUsageDescription</key>
	<string>OBRIX Pocket reads your music library to create unique creatures from your favorite songs. Your library is never uploaded — only metadata is used locally.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>OBRIX Pocket uses your location to flavor each specimen's sound with where you caught it. Your location is never shared.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>OBRIX Pocket captures a sound fingerprint of your environment to give each specimen a unique sonic character. No audio is recorded or stored.</string>
	<key>NSMotionUsageDescription</key>
	<string>OBRIX Pocket captures your movement pattern to give each specimen's modulation a unique character.</string>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>ObrixPocket uses Bluetooth to connect to external MIDI controllers.</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>ObrixPocket uses Bluetooth to connect to external MIDI controllers.</string>
	<key>NSNearbyInteractionUsageDescription</key>
	<string>ObrixPocket uses nearby interaction for collaborative play features.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>ObrixPocket sends OSC messages to music applications on your local network.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>fetch</string>
		<string>location</string>
		<string>remote-notification</string>
		<string>processing</string>
	</array>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBG</string>
	</dict>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UTExportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.json</string>
			</array>
			<key>UTTypeDescription</key>
			<string>XO Reef Configuration</string>
			<key>UTTypeIdentifier</key>
			<string>org.xo-ox.xoreef</string>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>xoreef</string>
				</array>
			</dict>
		</dict>
	</array>
</dict>
</plist>
