<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Bundle identification -->
    <key>CFBundleDisplayName</key>
    <string>OBRIX Pocket</string>
    <key>CFBundleIdentifier</key>
    <string>org.xo-ox.obrix-pocket</string>
    <key>CFBundleName</key>
    <string>ObrixPocket</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>

    <!-- Minimum iOS deployment target -->
    <key>MinimumOSVersion</key>
    <string>15.0</string>

    <!-- Launch screen: plain dark background, no storyboard -->
    <key>UILaunchScreen</key>
    <dict>
        <key>UIColorName</key>
        <string>LaunchScreenBackground</string>
        <!-- No UIImageName: pure dark solid color -->
    </dict>

    <!-- Required device capabilities: arm64 only -->
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arm64</string>
    </array>

    <!-- Background audio playback -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
    </array>

    <!-- Interface orientations: portrait + both landscapes -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <!-- iPad also supports upside-down portrait -->
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- Force dark mode (QDD LVL 4 Lucy) -->
    <key>UIUserInterfaceStyle</key>
    <string>Dark</string>

    <!-- Status bar: light content (white text on dark) -->
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleLightContent</string>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>

    <!-- Privacy descriptions -->
    <!-- Microphone: for future OSMOSIS live input -->
    <key>NSMicrophoneUsageDescription</key>
    <string>OBRIX Pocket uses the microphone for live audio input processing with the OSMOSIS engine.</string>

    <!-- Main storyboard: none (programmatic UI) -->
    <!-- UIMainStoryboardFile intentionally omitted -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
        <key>UISceneConfigurations</key>
        <dict>
            <key>UIWindowSceneSessionRoleApplication</key>
            <array>
                <dict>
                    <key>UISceneConfigurationName</key>
                    <string>Default Configuration</string>
                    <key>UISceneDelegateClassName</key>
                    <string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
                </dict>
            </array>
        </dict>
    </dict>
</dict>
</plist>
