{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "XO_OX default capabilities — file system access, dialogs, and shell",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "shell:allow-open"
  ]
}
