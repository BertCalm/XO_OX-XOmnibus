    "snap",
    "long",
    "tail",
    "resonant",
    "bell",
    "foundation"
  ],
  "macroLabels": [
    "SNAP AMOUNT",
    "TAIL LENGTH",
    "RESONANCE",
    "FILTER TONE"
  ],
  "couplingIntensity": "None",
  "tempo": null,
