    "metabolism",
    "stochastic",
    "coupled",
    "entangled",
    "slow"
  ],
  "macroLabels": [
    "CHARACTER",
    "MOVEMENT",
    "COUPLING",
    "SPACE"
  ],
  "couplingIntensity": "Deep",
  "tempo": null,
  "dna": {
    "brightness": 0.5,
    "warmth": 0.45,
    "movement": 0.78,
    "density": 0.68,
    "space": 0.58,
    "aggression": 0.42
  },
  "parameters": {
    "Oracle": {
      "oracle_breakpoints": 0.65,
      "oracle_stochasticRate": 0.55,
      "oracle_barrierMod": 0.48,
      "oracle_filterCutoff": 0.52,
      "oracle_outputLevel": 0.8
    },
    "Organon": {
      "organon_metabolicRate": 0.6,
      "organon_voiceCount": 4,
      "organon_filterCutoff": 0.55,
      "organon_reverbMix": 0.5,
      "organon_outputLevel": 0.78
    }
  },
  "coupling": {
    "pairs": [
      {
        "engineA": "Oracle",
        "engineB": "Organon",
        "type": "AudioToFM",
        "amount": 0.75
      },
      {
        "engineA": "Oracle",
