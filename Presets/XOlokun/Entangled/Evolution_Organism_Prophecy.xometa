        "amount": 0.55
      },
      {
        "engineA": "Oracle",
        "engineB": "Organon",
        "type": "EnvToMorph",
        "amount": 0.5
      }
    ]
  },
  "journey": {
    "durationSeconds": 60,
    "couplingEnvelope": "slow_sine_cycle",
    "startAmount": 0.25,
    "endAmount": 0.9,
    "description": "Coupling amount cycles on a 30-second sine — organism grows and starves repeatedly"
  },
  "sequencer": null
