  "guru_bin": {
    "retreat": "OBRIX — The Living Reef",
    "retreat_date": "2026-03-19",
    "vol": "Transcendental Vol 1",
    "scripture": [
      "Drift Bus = Berlin School Discovery",
      "Journey Paradox: journeyMode=1.0 only with driftDepth 0.6+"
    ],
    "revelation": "The music writes itself — the producer becomes a gardener, not a composer.",
    "god": "Schulze",
    "flock_note": "Ruby: 'I held a C major for 8 minutes. I never needed to play another note.'",
    "diagnosis": "A generative engine disguised as a synth patch — the Drift Bus is the composer."
  },
