  "guru_bin": {
    "retreat": "OUIE — The Hammerhead",
    "retreat_date": "2026-03-19",
    "vol": "Transcendental Vol 1",
    "scripture": [
      "At center, the hammer rests. Both voices exist without demanding the other's silence.",
      "Filter link is the treaty document — both voices breathe as one.",
      "The neutral zone is not emptiness. It is active restraint."
    ],
    "revelation": null,
    "god": null,
    "flock_note": "Do not move HAMMER. The entire preset is designed for HAMMER=0. Move it fractionally and the treaty cracks.",
    "diagnosis": "filterLink=1 at HAMMER=0.0 produces the most stable, rounded tone in the OUIE engine. Suits long pads, meditation contexts, and tonal foundation work under lead lines. The 0.067 Hz breath rate mirrors the ocean — physiologically settling."
  },
