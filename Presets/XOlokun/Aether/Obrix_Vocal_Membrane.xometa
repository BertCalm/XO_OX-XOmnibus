    "obrix",
    "aether",
    "vocal",
    "wavetable",
    "formant",
    "membrane",
    "biological",
    "vowel"
  ],
  "tier": "transcendental",
  "guru_bin": {
    "retreat": "OBRIX — The Living Reef",
    "retreat_date": "2026-03-19",
    "vol": "Transcendental Vol 1",
    "scripture": [
      "Resonance 0.28-0.32 = formant whisper",
      "Vocal WT + LP@660Hz vowel zone"
    ],
    "revelation": "The filter at 660 Hz with resonance 0.30 is not a filter — it is a throat.",
    "god": "Vangelis",
    "flock_note": "Ruby: 'I played this for a singer. She said it sounded like her own voice heard from outside her body.'",
    "diagnosis": "The acoustic membrane between silence and speech — biological synthesis."
  },
