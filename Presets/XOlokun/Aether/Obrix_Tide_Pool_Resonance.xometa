  "name": "Tide Pool Resonance",
  "mood": "Aether",
  "engines": [
    "Obrix"
  ],
  "description": "Triangle (gentle, odd harmonics only) + Sine (pure fundamental), proc1 LP at 1200 Hz with resonance 0.28 \u2014 the tide pool's surface tension made audible. When the resonance is 0.28, the filter peak is not a peak but a presence \u2014 you hear the water's weight. Proc3 is Reverb-adjacent (bypass) while the reverb FX carries the ambience. Long attack (0.35s) and golden ratio release (1.618s). The tide pool neither begins nor ends \u2014 it persists.",
  "tags": [
    "obrix",
    "aether",
    "tide-pool",
    "resonance",
    "triangle",
    "formant-whisper",
    "gentle",
    "harmonic"
  ],
  "tier": "transcendental",
  "guru_bin": {
    "retreat": "OBRIX \u2014 The Living Reef",
    "retreat_date": "2026-03-19",
    "vol": "Transcendental Vol 1",
    "scripture": [
      "Resonance 0.28-0.32 = formant whisper",
      "Release 1.618 = golden ratio decay"
    ],
    "revelation": "The tide pool does not flow \u2014 it accumulates. Every drop is still there.",
    "god": "Pearlman",
    "flock_note": "Ruby: 'This is the sound of patience \u2014 a synth that refuses to hurry.'",
    "diagnosis": "A contained world \u2014 the surface tension of water made into synthesis."
  },
