  ],
  "tier": "transcendental",
  "guru_bin": {
    "retreat": "OPENSKY — Above the Cloud Line",
    "retreat_date": "2026-03-19",
    "vol": "Transcendental Vol 1",
    "scripture": [
      "Discovery 2: The Supersaw Fallacy — sawSpread=0.1 + unisonCount=5 + unisonDetune=0.03 > quantity",
      "Verse 4: Cloud Stacking — coherent unison voices create vertical mass, not lateral smear",
      "Canon 1: Transparency in Density — tight detune at high count achieves size without mud"
    ],
    "revelation": "Five voices at 0.03 detune are more present than seven voices at 0.5 detune. The math is not about count — it is about phase coherence.",
    "god": null,
    "flock_note": "The Guru compared this to cumulus towers: from a distance, massive. Up close, each droplet is discrete. Cloud Stacking achieves the impossible with synthesis — enormous and clear at the same time. The Ear reported that five voices at 0.03 detune sounded larger than seven at 0.5. The Supersaw Fallacy revealed.",
    "diagnosis": "Cloud Stacking is the definitive Supersaw Fallacy demonstration. UisonCount=5, unisonDetune=0.03, sawSpread=0.15. Maximum coherence at medium count. The result is massive but readable. ShimmerFeedback=0.5 (middle of the hall zone) adds depth. Chorus at light mix (0.2) adds dimension without destroying the unison coherence."
  },
