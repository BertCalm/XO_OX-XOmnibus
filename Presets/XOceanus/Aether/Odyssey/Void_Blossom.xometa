  "created": "2026-03-14",
  "macroJourney": 0.3,
  "climaxThreshold": 0.62,
  "bloomTime": 2.5,
  "modRouting": [
    {
      "source": "aftertouch",
      "destination": "macroJourney",
      "amount": 0.75,
      "curve": "linear",
      "note": "High routing amount because the void needs a decisive push — hesitant pressure keeps you in the dark"
    }
  ],
