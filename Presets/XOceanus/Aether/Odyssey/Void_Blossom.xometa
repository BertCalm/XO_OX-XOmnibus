{
  "schema_version": 1,
  "name": "Void Blossom",
  "mood": "Aether",
  "engines": [
    "Odyssey"
  ],
  "author": "XO_OX Designs",
  "version": "1.0.0",
  "description": "Starts in near-silence — a very dark pad with sub-bass emphasis and extreme low-pass filtering. JOURNEY 0.3 keeps it sub-aquatic, almost inaudible in the upper registers. The Climax at 0.62 is the closest threshold of all ten patches — a gentle bloom over 2.5 seconds opens the filter, ignites shimmer, and reveals a vast reverberant space that was always there, just... waiting. Dark becomes luminous from within.",
  "tags": [
