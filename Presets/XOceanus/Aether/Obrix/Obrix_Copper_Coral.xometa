    "obrix",
    "aether",
    "bandpass",
    "formant-pair",
    "copper",
    "dual-resonance",
    "voice",
    "metallic"
  ],
  "tier": "transcendental",
  "guru_bin": {
    "retreat": "OBRIX — The Living Reef",
    "retreat_date": "2026-03-19",
    "vol": "Transcendental Vol 1",
    "scripture": [
      "Dual BP = formant pair",
      "Resonance 0.28-0.32 = formant whisper"
    ],
    "revelation": "Two resonant chambers, one voice — the coral has learned to speak with its skeleton.",
    "god": "Tomita",
    "flock_note": "Raj: 'I spent 20 minutes moving between octaves. Each note had a different vowel.'",
    "diagnosis": "A voice synthesized from mineral — copper coral singing a song about being copper."
  },
