    "aether",
    "harmonic",
    "wavetable",
    "fm",
    "wavefold",
    "complex",
    "quantum",
    "non-linear"
  ],
  "tier": "transcendental",
  "guru_bin": {
    "retreat": "OBRIX — The Living Reef",
    "retreat_date": "2026-03-19",
    "vol": "Transcendental Vol 1",
    "scripture": [
      "WT→FM→Wavefold chain",
      "Harmonic wtBank = dense partial structure",
      "FM Ceiling: 0.07-0.55 for musical timbres"
    ],
    "revelation": "Three stages of harmonic transformation produce a sound that cannot be described — only heard.",
    "god": "Schulze",
    "flock_note": "Ruby: 'Play a C. Now play it again. It was different, wasn't it? That's the quantum.'",
    "diagnosis": "A brick that contains multitudes — every note is a different universe of the same sound."
  },
