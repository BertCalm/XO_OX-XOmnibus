    "obrix",
    "aether",
    "wavefold",
    "aggressive",
    "overtone",
    "mono",
    "abyss",
    "harmonic-density"
  ],
  "tier": "transcendental",
  "guru_bin": {
    "retreat": "OBRIX — The Living Reef",
    "retreat_date": "2026-03-19",
    "vol": "Transcendental Vol 1",
    "scripture": [
      "Wavefold as harmonic multiplier",
      "HP after fold = overtone isolation"
    ],
    "revelation": "Stripping the fundamental after folding reveals the skeleton of the harmonic series — the sound of mathematics.",
    "god": "Buchla",
    "flock_note": "Rufus: 'This is the only patch that sounds violent and peaceful at the same time.'",
    "diagnosis": "A saw wave that has gone so deep it forgot what it was — the abyss stares back in harmonics."
  },
