  ],
  "tier": "transcendental",
  "guru_bin": {
    "retreat": "OPENSKY — Above the Cloud Line",
    "retreat_date": "2026-03-19",
    "vol": "Transcendental Vol 1",
    "scripture": [
      "Verse 12: Band-Pass Sky — filterType=BP removes sky's ground, leaving the alien luminous band",
      "Discovery 2: Shimmer Spectrum — feedback 0.60-0.80 enters cathedral zone, pitched tail becomes instrument",
      "Verse 6: The Aurora Principle — LFO on BP cutoff at 0.03 Hz creates curtain movement"
    ],
    "revelation": null,
    "god": null,
    "flock_note": "The Guru said: auroras are not warm. They are ionized. They do not comfort. They arrest. Band-pass filter removes warmth entirely — what remains is spectral, colored, other. The Ear reported: this is not a sky I have been to. The Eye saw the spectrum analyzer show a narrow band of energy shifting slowly upward and down. The curtains move. You are below them, looking up.",
    "diagnosis": "Aurora uses filterType=BP (1) centered at 3000 Hz to isolate the auroral frequency band. ShimmerFeedback=0.65 operates in the cathedral zone — the reverb tail is pitched and architectural. LFO2 at 0.03 Hz (one cycle over 33 seconds) slowly shifts the BP cutoff, creating the lateral motion of auroral curtains. This is OPENSKY's most alien character."
  },
