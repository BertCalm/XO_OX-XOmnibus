{
  "schema_version": 1,
  "name": "Geological Memory",
  "mood": "Atmosphere",
  "engines": ["Olvido"],
  "author": "XO_OX Designs",
  "version": "1.0.0",
  "description": "Time stretched to geological scale. Erosion at maximum (300 seconds), LFO moving at 0.01Hz — one full cycle every hundred seconds — and a 2-second attack that makes every note feel like strata forming. The reverb at 100% mix dissolves the source entirely into space. Memory link at 0.8 means this preset remembers everything.",
  "tags": ["ambient", "geological", "drone", "vast", "slow", "atmosphere", "reverb"],
  "macroLabels": ["CHARACTER", "MOVEMENT", "COUPLING", "SPACE"],
