{
  "schema_version": 1,
  "name": "Mellotron Ghost",
  "mood": "Atmosphere",
  "engines": ["Ostracon"],
  "author": "XO_OX Designs",
  "version": "1.0.0",
  "description": "The M400 lives here. Three heads on a 2-second reel capture the exact character of the original — oxide and flutter recreate the inconsistent tape path, flutter rate at 4.2Hz matches the mechanical flutter frequency of the original transport, and the 3800Hz low-pass filter mirrors the bandwidth ceiling of the original 3/8\" tape strips. Wow adds the slight pitch drift that made every Mellotron a unique instrument.",
  "tags": ["ostracon", "atmosphere", "mellotron", "tape", "vintage", "orchestral", "cinematic", "m400"],
  "macroLabels": ["CHARACTER", "MOVEMENT", "COUPLING", "SPACE"],
