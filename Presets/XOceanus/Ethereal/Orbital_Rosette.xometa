{
  "schema_version": 1,
  "name": "Orbital Rosette",
  "mood": "Ethereal",
  "engines": ["Ogive"],
  "author": "XO_OX Designs",
  "version": "1.0.0",
  "description": "A cinematic anchor designed for score and atmosphere. Pure sine tones fill 64 panes at a weightless 0.6 Hz free scan with a smooth lancet of 1.3 and soft 3200 Hz cutoff. An orchestral 0.35-second attack and 3.5-second release let notes arrive and recede like distant planets.",
  "tags": ["cinematic", "ethereal", "orchestral", "pads", "ambient", "score", "floating"],
  "macroLabels": ["CHARACTER", "MOVEMENT", "COUPLING", "SPACE"],
