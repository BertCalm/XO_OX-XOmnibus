  "guru_bin": {
    "retreat": "OVERDUB — Temporal Evolution and Degradation-as-Architecture",
    "retreat_date": "2026-03-21",
    "scripture": [
      "Scripture VII-3: Degradation Is Not Failure — It Is Memory Made Audible"
    ],
    "revelation": "Water filters the high frequencies first. Pressure changes what time means.",
    "diagnosis": "Fade Pressure explores OVERDUB below the water line — low cutoff, heavy damping on both reverb and delay, maximum drift. The tape degradation is not artistic choice here; it is acoustic physics. Slow oscillations in the sub range create beatings."
  },
