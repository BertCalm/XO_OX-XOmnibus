  "guru_bin": {
    "retreat": "OCEANDEEP — The Abyssal Zone",
    "retreat_date": "2026-03-19",
    "vol": "Transcendental Vol 1",
    "scripture": [
      "The dub bass has always been water. This makes it literal.",
      "pressureAmt=0.85: the ocean IS the compressor.",
      "filterCutoff=300: warm enough for the dance floor, dark enough for the abyss."
    ],
    "revelation": null,
    "god": null,
    "flock_note": "PRESSURE macro is the dub compressor. The higher you push it, the more the ocean sits on top of the bass. For classic reggae feel keep PRESSURE at 0.6-0.75. For deep dub spirituality push to 0.9 and let the bass nearly disappear.",
    "diagnosis": "pressureAmt=0.85: heavy hydrostatic compression gives authentic dub weight. filterCutoff=300 with filterRes=0.6: the dub resonant peak without excessive brightness. bodyChar=0 (Open Water): clean sub without waveguide coloration. This is the most playable preset in the collection."
  },
