{
  "schema_version": 1,
  "name": "Apotheosis",
  "mood": "Aether",
  "engines": ["Odyssey"],
  "author": "XO_OX Designs",
  "version": "1.0.0",
  "description": "The tenth and final Journey Demo — the one that shows everything at once. JOURNEY starts at 0.5, exactly at the midpoint: familiar and alien are in perfect balance, neither dominating. The Climax threshold sits at 0.8, the highest of the set — this is not an easy bloom. Hold a low chord, press into aftertouch past the threshold, and over 2 seconds all seven Signature Traits open simultaneously: drift accelerates, shimmer saturates, fracture begins to stutter, and the formants dissolve into a single sustained vowel that is every vowel. The name means what it says.",
  "tags": ["climax", "demo", "apotheosis", "journey", "signature", "all-traits", "transcendent", "aether", "finale", "dense", "complete"],
  "macroLabels": ["JOURNEY", "BREATHE", "BLOOM", "FRACTURE"],
  "couplingIntensity": "None",
  "tempo": null,
  "created": "2026-03-14",
  "macroJourney": 0.5,
  "climaxThreshold": 0.8,
  "bloomTime": 2.0,
  "modRouting": [
    {
      "source": "aftertouch",
      "destination": "macroJourney",
      "amount": 0.8,
      "curve": "linear",
      "note": "Maximum routing — the Apotheosis demands full physical commitment. 0.8 threshold plus 0.5 start means you need 0.375 of aftertouch travel. Not trivial. Worthy."
    }
  ],
