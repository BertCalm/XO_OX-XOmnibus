{
  "schema_version": 1,
  "name": "Spectral Mirror",
  "mood": "Entangled",
  "engines": [
    "Optic",
    "Odyssey",
    "Opal"
  ],
  "author": "XO_OX Designs",
  "version": "1.0.0",
  "description": "OPTIC analyzes Odyssey's pad and reflects spectral energy back as filter and morph modulation into Opal. Audio in, modulation out — the sound shapes itself.",
  "tags": [
    "spectral",
    "feedback",
    "evolving",
    "pad",
    "entangled"
  ],
  "macroLabels": [
    "REACTIVITY",
    "MOVEMENT",
    "COUPLING",
    "SPACE"
  ],
  "couplingIntensity": "High",
  "tempo": null,
  "dna": {
    "brightness": 0.55,
    "warmth": 0.6,
    "movement": 0.8,
    "density": 0.5,
    "space": 0.75,
    "aggression": 0.15
  },
  "parameters": {
    "Optic": {
      "optic_reactivity": 0.85,
      "optic_inputGain": 1.0,
      "optic_autoPulse": 0,
      "optic_pulseRate": 2.0,
      "optic_pulseShape": 0.5,
      "optic_pulseSwing": 0.0,
      "optic_pulseEvolve": 0.0,
      "optic_pulseSubdiv": 0.0,
      "optic_pulseAccent": 0.5,
      "optic_modDepth": 0.6,
      "optic_modMixPulse": 0.0,
      "optic_modMixSpec": 0.9,
      "optic_vizMode": 1,
      "optic_vizFeedback": 0.5,
      "optic_vizSpeed": 0.8,
      "optic_vizIntensity": 0.7
    },
    "Odyssey": {
      "odyssey_detune": 0.08
    },
    "Opal": {
      "opal_filterCutoff": 3000.0
    }
  },
  "coupling": {
    "pairs": [
      {
        "engineA": "Odyssey",
        "engineB": "Optic",
        "type": "AudioToFM",
        "amount": 0.6
      },
      {
        "engineA": "Optic",
        "engineB": "Opal",
        "type": "AmpToFilter",
        "amount": 0.55
      },
      {
        "engineA": "Optic",
        "engineB": "Opal",
        "type": "EnvToMorph",
        "amount": 0.4
      }
    ]
  },
  "sequencer": null
}
