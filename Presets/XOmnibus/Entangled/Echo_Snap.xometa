{
  "schema_version": 1,
  "name": "Echo Snap",
  "mood": "Entangled",
  "engines": ["Dub", "Snap"],
  "author": "XO_OX Designs",
  "version": "1.0.0",
  "description": "SNAP's envelope modulates DUB's filter — percussive hits duck the dub bass through the echo chamber. Classic sidechain dub.",
  "tags": ["echo", "snap", "coupled", "sidechain", "dub"],
  "macroLabels": ["SNAP DEPTH", "ECHO", "COUPLING", "SPACE"],
  "couplingIntensity": "Moderate",
  "tempo": null,
  "dna": {
    "brightness": 0.4,
    "warmth": 0.6,
    "movement": 0.7,
    "density": 0.5,
    "space": 0.5,
    "aggression": 0.5
  },
  "parameters": {
    "Dub": {
      "dub_oscWave": 2,
      "dub_oscOctave": 1,
      "dub_oscTune": 0.0,
      "dub_oscPwm": 0.5,
      "dub_subLevel": 0.6,
      "dub_noiseLevel": 0.0,
      "dub_drift": 0.04,
      "dub_level": 0.8,
      "dub_filterMode": 0,
      "dub_filterCutoff": 1200.0,
      "dub_filterReso": 0.3,
      "dub_filterEnvAmt": 0.2,
      "dub_attack": 0.005,
      "dub_decay": 0.5,
      "dub_sustain": 0.7,
      "dub_release": 0.3,
      "dub_pitchEnvDepth": 0.0,
      "dub_pitchEnvDecay": 0.015,
      "dub_lfoRate": 2.0,
      "dub_lfoDepth": 0.0,
      "dub_lfoDest": 0,
      "dub_sendLevel": 0.5,
      "dub_returnLevel": 0.6,
      "dub_dryLevel": 0.9,
      "dub_driveAmount": 1.2,
      "dub_delayTime": 0.375,
      "dub_delayFeedback": 0.55,
      "dub_delayWear": 0.3,
      "dub_delayWow": 0.15,
      "dub_delayMix": 0.4,
      "dub_reverbSize": 0.3,
      "dub_reverbDamp": 0.5,
      "dub_reverbMix": 0.2,
      "dub_voiceMode": 1,
      "dub_glide": 0.15,
      "dub_polyphony": 0
    },
    "Snap": {
