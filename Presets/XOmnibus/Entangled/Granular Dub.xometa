{
  "schema_version": 1,
  "name": "Granular Dub",
  "mood": "Entangled",
  "engines": ["XOpal", "XOverdub"],
  "author": "XO_OX",
  "version": "1.0.0",
  "description": "Grain cloud output fed through DUB's tape echo and spring reverb. Granulated dub.",
  "tags": ["dub", "granular", "echo", "tape"],
  "macroLabels": ["SCATTER", "DRIFT", "COUPLING", "SPACE"],
  "couplingIntensity": "Moderate",
  "tempo": null,
  "created": "2026-03-11",
  "legacy": {"sourceInstrument": null, "sourceCategory": null, "sourcePresetName": null},
  "parameters": {
    "XOpal": {
      "opal_source": 1,
      "opal_grainSize": 150.0,
      "opal_density": 30.0,
      "opal_position": 0.5,
      "opal_posScatter": 0.15,
      "opal_pitchScatter": 1.5,
      "opal_panScatter": 0.4,
      "opal_window": 2,
      "opal_freeze": 0.0,
      "opal_couplingLevel": 0.0,
      "opal_pulseWidth": 0.5,
      "opal_detuneCents": 8.0,
      "opal_filterCutoff": 5000.0,
      "opal_filterReso": 0.2,
      "opal_filterMode": 0,
      "opal_shimmer": 0.0,
      "opal_frost": 0.0,
      "opal_smear": 0.15,
      "opal_reverbMix": 0.15,
      "opal_ampAttack": 0.3,
      "opal_ampDecay": 0.4,
      "opal_ampSustain": 0.8,
      "opal_ampRelease": 1.5,
      "opal_masterVolume": 0.8
    }
  },
  "coupling": {
    "pairs": [
      {"source": "XOpal", "target": "XOverdub", "type": "AudioToWavetable", "amount": 0.7}
    ]
  },
  "sequencer": null,
  "dna": {"brightness": 0.4, "warmth": 0.5, "movement": 0.55, "density": 0.45, "space": 0.65, "aggression": 0.1}
}
