{
  "schema_version": 1,
  "name": "Time Slip Dub",
  "mood": "Atmosphere",
  "engines": ["Overdub"],
  "author": "XO_OX Designs",
  "version": "1.0.0",
  "description": "Anomaly Engine with Time-Slip enabled at 0.62 slip speed — the dub delay's wet signal gets reversed in time, creating backward dub tails that emerge before the forward repeats. Texture blend at 0.35 keeps the dry organic core present while the reverb size at 0.72 gives the reverse ghosts cathedral-scale space.",
  "tags": ["atmosphere", "dub", "anomaly", "reverse", "time-slip", "boutique", "fx_chain:Boutique", "boutique-fx-demo"],
