{
  "schema_version": 1,
  "name": "Classic Dub Bass",
  "mood": "Foundation",
  "engines": ["Dub"],
  "author": "XO_OX Designs",
  "version": "1.0.0",
  "description": "Warm, round dub bass with sub octave and gentle filter envelope. The foundation of any dub track.",
  "tags": ["bass", "dub", "warm", "sub", "classic"],
  "macroLabels": ["WEIGHT", "MOVEMENT", "COUPLING", "SPACE"],
  "couplingIntensity": "None",
  "tempo": null,
  "dna": {
    "brightness": 0.25,
    "warmth": 0.85,
    "movement": 0.2,
    "density": 0.4,
    "space": 0.2,
    "aggression": 0.3
  },
  "parameters": {
    "Dub": {
      "dub_oscWave": 2,
      "dub_oscOctave": 1,
      "dub_oscTune": 0.0,
      "dub_oscPwm": 0.5,
      "dub_subLevel": 0.7,
      "dub_noiseLevel": 0.0,
      "dub_drift": 0.03,
      "dub_level": 0.85,
      "dub_filterMode": 0,
      "dub_filterCutoff": 800.0,
      "dub_filterReso": 0.2,
      "dub_filterEnvAmt": 0.3,
      "dub_attack": 0.005,
      "dub_decay": 0.4,
      "dub_sustain": 0.6,
      "dub_release": 0.2,
      "dub_pitchEnvDepth": 0.0,
      "dub_pitchEnvDecay": 0.015,
      "dub_lfoRate": 2.0,
      "dub_lfoDepth": 0.0,
      "dub_lfoDest": 0,
      "dub_sendLevel": 0.0,
      "dub_returnLevel": 0.0,
      "dub_dryLevel": 1.0,
      "dub_driveAmount": 1.0,
      "dub_delayTime": 0.375,
      "dub_delayFeedback": 0.5,
      "dub_delayWear": 0.3,
      "dub_delayWow": 0.15,
      "dub_delayMix": 0.5,
      "dub_reverbSize": 0.4,
      "dub_reverbDamp": 0.5,
      "dub_reverbMix": 0.3,
      "dub_voiceMode": 1,
      "dub_glide": 0.2,
      "dub_polyphony": 0
    }
  },
  "coupling": null,
  "sequencer": null
}
