{
  "schema_version": 1,
  "name": "Dub Bass Foundation",
  "mood": "Foundation",
  "engines": ["Overdub"],
  "author": "XO_OX Designs",
  "version": "1.0.0",
  "description": "The core dub bass tone. Heavy sub, tape-saturated square wave, just enough echo to breathe. Every dub track starts here.",
  "tags": ["bass", "dub", "foundation", "sub", "tape", "core"],
  "macroLabels": ["TONE", "SUB LEVEL", "TAPE ECHO", "REVERB"],
  "couplingIntensity": "None",
  "tempo": null,
  "dna": {
    "brightness": 0.3,
    "warmth": 0.75,
    "movement": 0.3,
    "density": 0.65,
    "space": 0.4,
    "aggression": 0.4
  },
  "parameters": {
    "Overdub": {
      "dub_oscWave": 2,
      "dub_oscOctave": 0,
      "dub_oscTune": 0.0,
      "dub_oscPwm": 0.5,
      "dub_subLevel": 0.65,
      "dub_noiseLevel": 0.0,
      "dub_drift": 0.03,
      "dub_level": 0.85,
      "dub_filterMode": 0,
      "dub_filterCutoff": 1000.0,
      "dub_filterReso": 0.3,
      "dub_filterEnvAmt": 0.35,
      "dub_attack": 0.005,
      "dub_decay": 0.4,
      "dub_sustain": 0.7,
      "dub_release": 0.3,
      "dub_pitchEnvDepth": 0.06,
      "dub_pitchEnvDecay": 0.015,
      "dub_lfoRate": 0.5,
      "dub_lfoDepth": 0.0,
      "dub_lfoDest": 0,
      "dub_sendLevel": 0.45,
      "dub_returnLevel": 0.5,
      "dub_dryLevel": 0.9,
      "dub_driveAmount": 1.3,
      "dub_delayTime": 0.375,
      "dub_delayFeedback": 0.4,
      "dub_delayWear": 0.3,
      "dub_delayWow": 0.12,
      "dub_delayMix": 0.35,
      "dub_reverbSize": 0.3,
      "dub_reverbDamp": 0.6,
      "dub_reverbMix": 0.15,
      "dub_voiceMode": 1,
      "dub_glide": 0.0,
      "dub_polyphony": 0
    }
  },
  "coupling": {
    "pairs": []
  },
  "sequencer": null
}
