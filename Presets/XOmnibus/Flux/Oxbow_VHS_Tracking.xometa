{
  "author": "XO_OX Designs",
  "coupling": { "pairs": [] },
  "couplingIntensity": "None",
  "description": "Wobbling, unstable reverb inspired by VHS tracking errors. High erosion rate creates pitch drift while entanglement smears the stereo field.",
  "dna": { "brightness": 0.3, "warmth": 0.55, "movement": 0.6, "density": 0.4, "space": 0.35, "aggression": 0.2 },
  "engines": ["Oxbow"],
  "macroLabels": ["ENTANGLE", "EROSION", "CONVERGE", "CANTILEVER"],
  "mood": "Flux",
  "name": "VHS Tracking",
  "parameters": {
    "Oxbow": {
      "oxb_size": 0.3,
      "oxb_decay": 2.0,
      "oxb_entangle": 0.55,
      "oxb_erosionRate": 0.25,
      "oxb_erosionDepth": 0.7,
      "oxb_convergence": 4,
      "oxb_resonanceQ": 5,
      "oxb_resonanceMix": 0.15,
      "oxb_cantilever": 0.45,
      "oxb_damping": 2400,
      "oxb_predelay": 12,
      "oxb_dryWet": 0.4,
      "oxb_exciterDecay": 0.012,
      "oxb_exciterBright": 0.45
    }
  },
  "schema_version": 1,
  "tags": ["lo-fi", "vhs", "tracking", "wobble", "glitch"],
  "version": "1.0.0"
