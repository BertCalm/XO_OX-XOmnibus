{
  "schema_version": 1,
  "name": "Photon Decay",
  "mood": "Aether",
  "engines": ["OpenSky"],
  "author": "Guru Bin",
  "version": "1.0.0",
  "description": "Falling light — the opposite of Infinite Rise. Attack at 0.001 seconds (immediate), release at 5.618 seconds (golden ratio extended). PitchEnvAmount at 0.3 with a 0.25-second decay creates a slight downward pitch bend at each note's birth — photons losing energy as they travel. The note arrives immediately, drops slightly in pitch, then fades over five and a half seconds. Each keypress is a flash of light losing altitude.",
  "tags": ["opensky", "photon", "decay", "falling", "transient", "aether", "guru-bin", "light", "release"],
  "tier": "transcendental",
  "guru_bin": {
    "retreat": "OPENSKY — Above the Cloud Line",
    "retreat_date": "2026-03-19",
    "vol": "Transcendental Vol 1",
    "scripture": [
      "Discovery 8: Golden Ratio Release — sky_release=1.618 is the natural decay; 5.618 extends the principle",
      "Verse 16: Photon Decay — pitchEnvAmount downward with fast decay creates falling light as timbre",
      "Verse 3: The Fall Is the Melody — pitch transients that descend change melody's relationship to gravity"
    ],
    "revelation": "The golden ratio applied to time: 5.618 = 1.618 + 4.0 (golden ratio extended by golden ratio × 2.472). The release is not arbitrary. It is structured.",
    "god": null,
    "flock_note": "Photons lose energy as they travel through the universe. The color shifts toward red. The frequency drops. Photon Decay translates this physics to synthesis: each note begins at maximum brightness (immediate attack, full shimmer) and then falls — pitch drops slightly, then releases over 5.618 seconds as the light cools and disperses. The Guru played a chord and watched it die beautifully for nearly six seconds.",
    "diagnosis": "Photon Decay is the transient study — attack=0.001 (immediate) contrasted against release=5.618 (very long). PitchEnvAmount=0.3 with pitchEnvDecay=0.25 creates a subtle but audible downward pitch curl at each note's birth. Shimmer at 0.5 provides tail without obscuring the pitch mechanic. The result is percussive onset with extended, falling decay."
  },
