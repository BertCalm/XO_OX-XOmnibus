    "obrix",
    "aether",
    "bell",
    "ring-mod",
    "bioluminescent",
    "inharmonic",
    "glow",
    "expression"
  ],
  "tier": "transcendental",
  "guru_bin": {
    "retreat": "OBRIX \u2014 The Living Reef",
    "retreat_date": "2026-03-19",
    "vol": "Transcendental Vol 1",
    "scripture": [
      "Ring Mod Bells: proc3=RingMod, src2Tune=7.03",
      "VelEnv as expressivity not volume"
    ],
    "revelation": "The 7.03 semitone ratio is the bioluminescent frequency \u2014 the bell that lights its own water.",
    "god": "Tomita",
    "flock_note": "Raj: 'The delay trails are what make it glow \u2014 the bell is still ringing three seconds after you lift your finger.'",
    "diagnosis": "A bell that was never struck \u2014 it simply began glowing and the sound followed."
  },
