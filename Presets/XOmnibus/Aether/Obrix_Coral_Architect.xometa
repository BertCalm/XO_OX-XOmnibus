    "retreat": "OBRIX — The Living Reef",
    "retreat_date": "2026-03-19",
    "vol": "Transcendental Vol 1",
    "scripture": ["Brick Independence B016", "Modulation is the Lifeblood D002"],
    "revelation": "The reef is not one structure — it is many independent builders whose output becomes inseparable.",
    "god": "Buchla",
    "flock_note": "Ruby noted that coprime LFOs create a horizon that producers never reach but always chase.",
    "diagnosis": "A sound that reveals new rooms every time you walk through it."
