  "tier": "transcendental",
  "guru_bin": {
    "retreat": "OSTINATO — Transcendental Vol 1",
    "retreat_date": "2026-03-19",
    "scripture": [
      "Verse: The Swing Geography — 33% swing is the ancestral West African 12/8 triplet feel",
      "Verse: The GATHER Macro Is Social Dynamics — 0.5 for live ensemble feel"
    ],
    "revelation": "Pressura spoke: The atsimevu master drum in Agbadza is the djembe at -2 tuning with full articulation cycling (tone/slap/bass/mute across the pattern). The sogo and kidi are dunduns at +3 and +7. The axatse gourd shaker is approximated by beatbox hi-hat at fast pattern rate.",
    "god": "Pressura",
    "flock_note": "The Breath confirmed: at 33% swing, the patterns lock into the 12/8 feel that defines Ewe music. The Tongue noted: velocity sensitivity at 0.9 lets the master drum player express the call-and-response dynamics that make Agbadza come alive.",
    "diagnosis": "Ewe Agbadza was drums in a pattern. It is now a dance ceremony in Anloga, Ghana, where the atsimevu speaks and the community responds."
  },
