{
  "schema_version": 1,
  "name": "Pitch Rain",
  "mood": "Prism",
  "engines": ["Opal"],
  "author": "Guru Bin — OPAL Deep Expansion 2026-03-16",
  "version": "1.0.0",
  "description": "pitchScatter is the primary voice here — at rest it sits at 0.25, giving each grain a slightly different pitch, producing a shimmering halo around the played note. Mod wheel sweeps pitchScatter to maximum: the played pitch becomes a suggestion and the grains scatter across the octave like a chord no one composed. Velocity controls density so a soft key produces one pitched grain at a time — individual drops — while a hard key floods the field. An instrument for playing weather.",
  "tags": ["granular", "prism", "pitch-scatter", "mod-wheel", "velocity", "harmonic", "rain", "stochastic"],
