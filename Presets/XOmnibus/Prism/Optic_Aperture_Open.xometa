  "couplingIntensity": "None",
  "created": "2026-03-16",
  "description": "OPTIC as a performable light instrument. AutoPulse idle at slow rate — a resting phosphorescent heartbeat. Mod wheel opens the aperture: pulseRate accelerates and modDepth swells, moving from low glow to strobe event. At full wheel, the visual modulation engine is running at maximum density, driving downstream engines in any coupled setup. Aftertouch overloads vizIntensity and scanline density — pressing hard makes the display bloom into oversaturation, the phosphor burning through. Velocity sets the initial inputGain: whisper-touches catch only ambient signal; hard strikes slam the detector into saturation from the first moment. The aperture is yours to control.",
  "dna": {
    "aggression": 0.1,
    "brightness": 0.3,
    "density": 0.2,
    "movement": 0.35,
    "space": 0.55,
    "warmth": 0.2
  },
  "engines": [
    "Optic"
  ],
  "macroLabels": [
    "PULSE RATE",
    "BRIGHTNESS",
    "DENSITY",
    "AGGRESSION"
  ],
  "modMatrix": [
    {
      "amount": 0.85,
      "destination": "optic_pulseRate",
      "source": "modWheel"
    },
    {
      "amount": 0.8,
      "destination": "optic_modDepth",
      "source": "modWheel"
    },
    {
      "amount": 0.6,
      "destination": "optic_pulseEvolve",
      "source": "modWheel"
    },
    {
      "amount": 0.9,
      "destination": "optic_vizIntensity",
      "source": "aftertouch"
    },
    {
      "amount": 0.6,
      "destination": "optic_vizFeedback",
      "source": "aftertouch"
    },
    {
      "amount": 0.7,
      "destination": "optic_inputGain",
      "source": "velocity"
    },
    {
      "amount": 0.5,
      "destination": "optic_reactivity",
      "source": "velocity"
    }
  ],
  "mood": "Prism",
  "name": "Aperture Open",
  "parameters": {
    "Optic": {
      "optic_autoPulse": 1,
      "optic_inputGain": 0.8,
      "optic_modDepth": 0.1,
      "optic_modMixPulse": 0.6,
