<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">

    <!-- ------------------------------------------------------------------ -->
    <!-- Product metadata                                                     -->
    <!-- ------------------------------------------------------------------ -->
    <title>XOceanus — for all</title>
    <organization>org.xo-ox</organization>
    <domains enable_localSystem="true" enable_currentUserHome="true"/>
    <options customize="allow" require-scripts="false" rootVolumeOnly="false"/>

    <!-- ------------------------------------------------------------------ -->
    <!-- Installer UI pages                                                   -->
    <!-- ------------------------------------------------------------------ -->
    <welcome    file="welcome.html"    mime-type="text/html"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>

    <!-- ------------------------------------------------------------------ -->
    <!-- OS + hardware requirements                                           -->
    <!-- ------------------------------------------------------------------ -->
    <os-version min="12.0"/>

    <allowed-os-versions>
        <!-- macOS 12 Monterey and later -->
        <os-version min="12.0"/>
    </allowed-os-versions>

    <!-- Accept both Apple Silicon and Intel (universal binary) -->
    <volume-check>
        <allowed-architectures>
            <architecture>x86_64</architecture>
            <architecture>arm64</architecture>
        </allowed-architectures>
    </volume-check>

    <!-- ------------------------------------------------------------------ -->
    <!-- Package references                                                   -->
    <!-- ------------------------------------------------------------------ -->
    <pkg-ref id="org.xo-ox.xoceanus.au"
             version="1.0.0"
             onConclusion="none">XOceanus-AU.pkg</pkg-ref>

    <pkg-ref id="org.xo-ox.xoceanus.standalone"
             version="1.0.0"
             onConclusion="none">XOceanus-Standalone.pkg</pkg-ref>

    <pkg-ref id="org.xo-ox.xoceanus.presets"
             version="1.0.0"
             onConclusion="none">XOceanus-Presets.pkg</pkg-ref>

    <!-- ------------------------------------------------------------------ -->
    <!-- Choice declarations                                                  -->
    <!-- ------------------------------------------------------------------ -->

    <!-- AU Plugin (required) -->
    <choice id="org.xo-ox.xoceanus.choice.au"
            title="AU Plugin"
            description="Installs XOceanus.component to /Library/Audio/Plug-Ins/Components/ for use in any AU-compatible DAW (Logic Pro, GarageBand, Ableton Live, Bitwig, etc.)."
            start_selected="true"
            start_enabled="false"
            start_visible="true">
        <pkg-ref id="org.xo-ox.xoceanus.au"/>
    </choice>

    <!-- Standalone App (optional) -->
    <choice id="org.xo-ox.xoceanus.choice.standalone"
            title="Standalone Application"
            description="Installs XOceanus.app to /Applications/ for use without a DAW."
            start_selected="true"
            start_enabled="true"
            start_visible="true">
        <pkg-ref id="org.xo-ox.xoceanus.standalone"/>
    </choice>

    <!-- Factory Presets (default on) -->
    <choice id="org.xo-ox.xoceanus.choice.presets"
            title="Factory Presets"
            description="Installs ~17,300 factory presets (15 mood categories) to ~/Library/Audio/Presets/XO_OX/XOceanus/."
            start_selected="true"
            start_enabled="true"
            start_visible="true">
        <pkg-ref id="org.xo-ox.xoceanus.presets"/>
    </choice>

    <!-- ------------------------------------------------------------------ -->
    <!-- Choice outline                                                       -->
    <!-- ------------------------------------------------------------------ -->
    <choices-outline>
        <line choice="org.xo-ox.xoceanus.choice.au"/>
        <line choice="org.xo-ox.xoceanus.choice.standalone"/>
        <line choice="org.xo-ox.xoceanus.choice.presets"/>
    </choices-outline>

</installer-gui-script>
