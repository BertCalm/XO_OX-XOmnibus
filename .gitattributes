# XOlokun — Git line-ending normalization
# Ensures consistent LF line endings in the repository regardless of contributor OS.

# Default: normalise all text files to LF on commit
* text=auto eol=lf

# Explicitly text files
*.cpp       text eol=lf
*.h         text eol=lf
*.hpp       text eol=lf
*.c         text eol=lf
*.py        text eol=lf
*.cmake     text eol=lf
CMakeLists.txt text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.json      text eol=lf
*.xometa    text eol=lf
*.xml       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.swift     text eol=lf
*.sh        text eol=lf
.gitignore  text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf

# Binary files — never diff or modify
*.wav       binary
*.WAV       binary
*.aiff      binary
*.mp3       binary
*.ogg       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.icns      binary
*.pdf       binary
*.xpn       binary
*.xoc       binary
